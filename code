    <script>
        function changeColor(event) {
            const x = event.clientX / window.innerWidth;
            const y = event.clientY / window.innerHeight;
            
            const color1 = interpolateColor('#c182ff', '#a53ed5', x, y);
            const color2 = interpolateColor('#a53ed5', '#c182ff', x, y);

            document.body.style.setProperty('--color1', color1);
            document.body.style.setProperty('--color2', color2);
        }

        function interpolateColor(color1, color2, x, y) {
            const hex = (color) => parseInt(color.slice(1), 16);
            const componentToHex = (c) => {
                const hex = c.toString(16);
                return hex.length === 1 ? '0' + hex : hex;
            };
            
            const r = Math.floor(hex(color1) * (1 - x) + hex(color2) * x);
            const g = Math.floor(hex(color1.slice(3, 5)) * (1 - y) + hex(color2.slice(3, 5)) * y);
            const b = Math.floor(hex(color1.slice(5, 7)) * (1 - x) + hex(color2.slice(5, 7)) * x);
            
            return `#${componentToHex(r)}${componentToHex(g)}${componentToHex(b)}`;
        }
    </script>
